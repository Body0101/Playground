{
  "name": "smart-attendance-server",
  "version": "2.0.0",
  "description": "Smart Attendance System — ESP32 + RFID + Web App",
  "main": "server.js",
  "scripts": {
    "start":           "node server.js",
    "dev":             "nodemon server.js",
    "setup":           "node scripts/setup.js",
    "migrate":         "node db/migrate.js up",
    "migrate:down":    "node db/migrate.js rollback",
    "migrate:status":  "node db/migrate.js status",
    "seed":            "node db/seed.js",
    "backup":          "node db/backup.js",
    "backup:list":     "node db/backup.js --list"
  },
  "dependencies": {
    "express":        "^4.18.2",
    "better-sqlite3": "^9.4.3",
    "bcryptjs":       "^2.4.3",
    "jsonwebtoken":   "^9.0.2",
    "socket.io":      "^4.7.4",
    "cors":           "^2.8.5",
    "dotenv":         "^16.4.5",
    "qrcode":         "^1.5.3"
  },
  "devDependencies": {
    "nodemon": "^3.0.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
