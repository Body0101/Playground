# ============================================
#   Smart Attendance System — Environment
# ============================================
# Copy this file to .env and fill in values.
# NEVER commit the real .env to git.
# ============================================

# ─── Server ───────────────────────────────
PORT=3000

# ─── Security ─────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_STRING

# ─── Database ─────────────────────────────
# Directory where attendance.db lives (default: ./data)
DB_DIR=./data
DB_FILE=attendance.db

# ─── Backups ──────────────────────────────
# Set to "true" to enable automatic backups when server starts
AUTO_BACKUP=false

# How many backup files to keep (oldest are deleted automatically)
MAX_BACKUPS=10

# Backup interval in milliseconds (default 6h = 21600000)
BACKUP_EVERY=21600000
